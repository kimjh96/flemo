{
  "extends": "@flemo/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".source/server.ts",
    ".source/browser.ts",
    ".source/dynamic.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
