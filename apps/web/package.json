  "dependencies": {
    "@flemo/core": "workspace:*",
    "@flemo/react": "workspace:*",
    "@flemo/react-layout": "workspace:*",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@flemo/eslint-config": "workspace:*",
    "@flemo/tsconfig": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
