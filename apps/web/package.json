{
  "name": "@flemo/web",
  "version": "0.6.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fumadocs-mdx && next dev -p 3000",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "lint": "eslint \"**/*.{js,mjs,ts,jsx,tsx,mts}\"",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "clean": "rm -rf .next .turbo playwright-report test-results"
  },
  "dependencies": {
    "@flemo/core": "workspace:*",
    "@flemo/react": "workspace:*",
    "@flemo/react-layout": "workspace:*",
    "fumadocs-core": "^16.10.5",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.5",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@flemo/eslint-config": "workspace:*",
    "@flemo/tsconfig": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
