{
  "name": "@flemo/web",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fumadocs-mdx && next dev -p 3000",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "lint": "eslint \"**/*.{js,mjs,ts,jsx,tsx,mts}\"",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "clean": "rm -rf .next .turbo playwright-report test-results"
  },
  "dependencies": {
    "@flemo/core": "workspace:*",
    "@flemo/react": "workspace:*",
    "@flemo/react-layout": "workspace:*",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "motion": "^12.0.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@flemo/eslint-config": "workspace:*",
    "@flemo/tsconfig": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.33.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.2"
  }
}
