    "csstype": "^3.2.3",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
