{
  "extends": "@flemo/tsconfig/react-library.json",
  "compilerOptions": {
    "rootDir": "./src",

    "paths": {
      "@history": ["./src/history"],
      "@history/*": ["./src/history/*"],
      "@navigate": ["./src/navigate"],
      "@navigate/*": ["./src/navigate/*"],
      "@renderer": ["./src/renderer"],
      "@renderer/*": ["./src/renderer/*"],
      "@screen": ["./src/screen"],
      "@screen/*": ["./src/screen/*"],
      "@stores": ["./src/stores"],
      "@stores/*": ["./src/stores/*"],
      "@transition": ["./src/transition"],
      "@transition/*": ["./src/transition/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@Route": ["./src/Route"],
      "@Route/*": ["./src/Route/*"],
      "@Router": ["./src/Router"],
      "@Router/*": ["./src/Router/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
