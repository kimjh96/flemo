{
  "name": "flemo-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for flemo: a React router library with native-like screen transitions, plus its docs/landing site.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimjh96/flemo.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write --config ./.prettierrc \"**/*.{js,mjs,ts,jsx,tsx,mts,json,md,mdx}\"",
    "convention": "pnpm format && turbo run lint -- --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=\"./packages/*\" && changeset publish",
    "build:packages": "turbo run build --filter=@flemo/core --filter=@flemo/react --filter=@flemo/react-layout",
    "size": "size-limit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "size-limit": "^12.1.0",
    "turbo": "^2.10.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.23.1"
  },
  "lint-staged": {
    "*.{js,mjs,ts,jsx,tsx,mts,json,md,mdx}": "prettier --write --ignore-unknown"
  }
}
